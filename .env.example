# ===========================
# 搴旂敤閰嶇疆
# ===========================
APP_NAME=鏅鸿兘闈㈣瘯鍔╂墜
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# ===========================
# 鏁版嵁搴撻厤缃?
# ===========================
DB_HOST=localhost
DB_PORT=3306
DB_USER=interview
DB_PASSWORD=interview123
DB_NAME=interview_assistant
DB_ROOT_PASSWORD=interview123
DATABASE_URL=mysql+pymysql://interview:interview123@localhost:3306/interview_assistant

# ===========================
# Redis 閰嶇疆
# ===========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ===========================
# LLM 澶фā鍨嬮厤缃紙DeepSeek锛?
# ===========================
# DeepSeek API 瀵嗛挜 鈥斺€?璇峰湪 https://platform.deepseek.com/api_keys 鑾峰彇
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-chat
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

# DeepSeek 鎬濊€冩ā寮忥紙闈㈣瘯鍦烘櫙寤鸿寮€鍚紝妯″瀷浼氬厛鎺ㄧ悊鍐嶅洖绛旓級
LLM_THINKING_ENABLED=true
# 鎺ㄧ悊寮哄害: high锛堥粯璁わ級| max锛堝鏉?Agent 鍦烘櫙锛?
LLM_REASONING_EFFORT=high

# Embedding 妯″瀷
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu

# ===========================
# 鍚戦噺鏁版嵁搴撻厤缃?
# ===========================
CHROMA_PERSIST_DIR=./chroma_db

# ===========================
# 璇煶璇嗗埆閰嶇疆
# ===========================
# 闃块噷浜戣闊宠瘑鍒?
ALIYUN_ASR_APP_KEY=
ALIYUN_ASR_ACCESS_KEY=
ALIYUN_ASR_ACCESS_SECRET=
# 鎴栦娇鐢?OpenAI Whisper
WHISPER_API_KEY=

# ===========================
# 鏂囦欢涓婁紶閰嶇疆
# ===========================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.mp3,.wav,.m4a,.ogg

# ===========================
# JWT 璁よ瘉閰嶇疆
# ===========================
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================
# 鏈嶅姟绔彛
# ===========================
BACKEND_PORT=8000
FRONTEND_PORT=80

# ===========================
# 鍓嶇閰嶇疆
# ===========================
VITE_API_BASE_URL=/api
